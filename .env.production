# Variables públicas — Cloudflare inyecta desde [vars] en wrangler.demo.toml/wrangler.live.toml
# El anon key es público por diseño (va en el bundle del browser, protegido por RLS).
# Los SECRETOS (SUPABASE_SERVICE_ROLE_KEY, RESEND_API_KEY, CRON_SECRET) NUNCA van aquí:
# se configuran en Cloudflare → Worker → Settings → Variables and Secrets.
NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
